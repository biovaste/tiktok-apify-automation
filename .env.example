# Copy to .env for local runs:  cp .env.example .env   (then fill in)
# In GitHub Actions these come from repo Secrets instead — see README.

# Apify API token — Apify Console -> Settings -> Integrations -> API token
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google service-account credentials. LOCAL: point to the downloaded JSON file.
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# CI alternative: instead of a file, paste the whole JSON into one variable.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# Your tracker's Google Sheet ID and TikTok handle. Kept out of config.yaml so
# that file can live in a public repo. (In GitHub Actions set these as repo
# Variables instead — Settings -> Secrets and variables -> Actions -> Variables.)
SPREADSHEET_ID=your_google_sheet_id
TIKTOK_USERNAME=your_tiktok_handle
